@*
    =========================================================================
     BBiComporEmail.razor  —  Composição do corpo do e-mail (peça 2)
    -------------------------------------------------------------------------
     Dois modos de edição sobre o MESMO corpo HTML (fonte única de verdade):
       - NORMAL: imagem de cabeçalho + bloco de texto (com marcadores) + imagem
         de rodapé. As imagens viram anexos INLINE (cid:bbi-cabecalho /
         cid:bbi-rodape), guardados na lista Anexos do template.
       - AVANÇADO: edição livre do HTML.
     Transição normal->avançado é só-ida; "voltar ao normal" fica ativo apenas
     enquanto o HTML não foi editado (comparação com o snapshot).

     Comuns aos dois: preview ao vivo (iframe isolado; troca cid: por data URI),
     menu de contexto "Adicionar campo" e validação de marcadores.

     Depende de BBiEmail.cs (BBiCore.Email) e de wwwroot/bbiComporEmail.js.

     >>> NOTA PARA REORGANIZAÇÃO: componente coeso; manter junto do .js e no
     namespace BBiCore.Componentes.
    =========================================================================
*@
@namespace BBiCore.Componentes
@using System.Text
@using System.Text.RegularExpressions
@using BBiCore.Email
@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="bbi-email">
    <div class="bbi-email__topo">
        <div class="bbi-email__modos">
            <span class="bbi-email__modo @(EhNormal ? "bbi-email__modo--ativo" : "")">Normal</span>
            <span class="bbi-email__seta">→</span>
            <span class="bbi-email__modo @(!EhNormal ? "bbi-email__modo--ativo" : "")">Avançado</span>
        </div>

        @if (EhNormal)
        {
            <button type="button" class="bbi-email__acao" @onclick="IrParaAvancado">Ir para o modo avançado</button>
        }
        else if (PodeVoltar)
        {
            <button type="button" class="bbi-email__acao bbi-email__acao--sec" @onclick="VoltarParaNormal">Voltar ao modo normal</button>
        }
        else
        {
            <span class="bbi-email__travado">HTML editado — o modo normal não está mais disponível para este conteúdo.</span>
        }
    </div>

    <div class="bbi-email__dica">
        Clique com o botão direito no editor para <strong>adicionar um campo</strong>.
        Para copiar, colar ou recortar, use os atalhos do teclado (Ctrl+C / Ctrl+V / Ctrl+X).
    </div>

    <div class="bbi-email__grade">
        <div class="bbi-email__col">
            @if (EhNormal)
            {
                <div class="bbi-email__bloco">
                    <span class="bbi-email__rotulo">Imagem de cabeçalho</span>
                    @if (_cabecalhoDataUri is null)
                    {
                        <InputFile OnChange="AoSubirCabecalho" accept="image/*" />
                    }
                    else
                    {
                        <div class="bbi-email__img">
                            <img src="@_cabecalhoDataUri" alt="cabeçalho" />
                            <button type="button" class="bbi-email__remover" @onclick="RemoverCabecalho">Remover</button>
                        </div>
                    }
                </div>

                <label class="bbi-email__rotulo" for="@_idNormal">Texto do e-mail</label>
                <textarea id="@_idNormal"
                          class="bbi-email__texto"
                          value="@_texto"
                          @oninput="AoDigitarTexto"
                          @oncontextmenu="e => AbrirMenu(e, _idNormal)"
                          @oncontextmenu:preventDefault="true"></textarea>

                <div class="bbi-email__bloco">
                    <span class="bbi-email__rotulo">Imagem de rodapé</span>
                    @if (_rodapeDataUri is null)
                    {
                        <InputFile OnChange="AoSubirRodape" accept="image/*" />
                    }
                    else
                    {
                        <div class="bbi-email__img">
                            <img src="@_rodapeDataUri" alt="rodapé" />
                            <button type="button" class="bbi-email__remover" @onclick="RemoverRodape">Remover</button>
                        </div>
                    }
                </div>
            }
            else
            {
                <label class="bbi-email__rotulo" for="@_idAvancado">HTML do e-mail</label>
                <textarea id="@_idAvancado"
                          class="bbi-email__editor"
                          spellcheck="false"
                          value="@Corpo"
                          @oninput="AoDigitarHtml"
                          @oncontextmenu="e => AbrirMenu(e, _idAvancado)"
                          @oncontextmenu:preventDefault="true"></textarea>
            }
        </div>

        <div class="bbi-email__col">
            <span class="bbi-email__rotulo">Pré-visualização</span>
            <iframe class="bbi-email__preview" sandbox="" srcdoc="@_preview"></iframe>
        </div>
    </div>

    @if (_faltantes.Count > 0)
    {
        <div class="bbi-email__falhas">
            <strong>Campos não encontrados:</strong>
            @string.Join(", ", _faltantes.Select(f => "{{" + f + "}}"))
        </div>
    }

    @if (_menuAberto)
    {
        <div class="bbi-email__backdrop" @onclick="FecharMenu"></div>
        <div class="bbi-email__menu" style="left:@(_menuX)px; top:@(_menuY)px;">
            <div class="bbi-email__menu-titulo">Adicionar campo</div>
            @foreach (IGrouping<GrupoCampo, CampoTemplate> grupo in _campos.GroupBy(c => c.Grupo))
            {
                <div class="bbi-email__menu-grupo">@RotuloGrupo(grupo.Key)</div>
                @foreach (CampoTemplate campo in grupo)
                {
                    <button type="button" class="bbi-email__menu-item" @onclick="() => InserirCampo(campo)">@campo.Rotulo</button>
                }
            }
            @if (_campos.Count == 0)
            {
                <div class="bbi-email__menu-vazio">Nenhum campo disponível.</div>
            }
        </div>
    }
</div>

@code {
    /// <summary>Tipo do objeto de dados (ex.: PedidoCliente) que alimenta os campos e a validação. Obrigatório.</summary>
    [Parameter, EditorRequired] public Type TipoDados { get; set; } = default!;

    /// <summary>Motor configurado com variáveis e computados. Obrigatório.</summary>
    [Parameter, EditorRequired] public MotorTemplateEmail Motor { get; set; } = default!;

    /// <summary>Instância de exemplo para o preview aparecer preenchido. Se nulo, mostra os marcadores destacados.</summary>
    [Parameter] public object? DadosExemplo { get; set; }

    /// <summary>Corpo HTML do e-mail (bindável com <c>@bind-Corpo</c>).</summary>
    [Parameter] public string Corpo { get; set; } = string.Empty;

    /// <summary>Notifica mudança do corpo (par de <see cref="Corpo"/>).</summary>
    [Parameter] public EventCallback<string> CorpoChanged { get; set; }

    /// <summary>Modo de criação atual (bindável com <c>@bind-Origem</c>).</summary>
    [Parameter] public OrigemCriacaoTemplate Origem { get; set; }

    /// <summary>Notifica mudança do modo (par de <see cref="Origem"/>).</summary>
    [Parameter] public EventCallback<OrigemCriacaoTemplate> OrigemChanged { get; set; }

    /// <summary>Lista de anexos do template. O componente mantém aqui as imagens inline (cabeçalho/rodapé).</summary>
    [Parameter] public IList<IAnexoTemplate>? Anexos { get; set; }

    /// <summary>ContentId da imagem de cabeçalho inline.</summary>
    private const string CidCabecalho = "bbi-cabecalho";

    /// <summary>ContentId da imagem de rodapé inline.</summary>
    private const string CidRodape = "bbi-rodape";

    /// <summary>Tamanho máximo de imagem inline aceita (5 MB).</summary>
    private const long LimiteImagemBytes = 5L * 1024 * 1024;

    /// <summary>Regex que casa apenas o marcador duplo, para destaque no preview.</summary>
    private static readonly Regex RxMarcador =
        new(@"\{\{\s*([A-Za-z_][A-Za-z0-9_.]*)\s*(?::(.+?))?\s*\}\}", RegexOptions.Compiled);

    /// <summary>Id do textarea do modo avançado.</summary>
    private readonly string _idAvancado = $"bbi-adv-{Guid.NewGuid():N}";

    /// <summary>Id do textarea do modo normal.</summary>
    private readonly string _idNormal = $"bbi-nor-{Guid.NewGuid():N}";

    /// <summary>Campos disponíveis para inserção.</summary>
    private IReadOnlyList<CampoTemplate> _campos = [];

    /// <summary>HTML preparado para o preview.</summary>
    private string _preview = string.Empty;

    /// <summary>Marcadores não encontrados.</summary>
    private IReadOnlyList<string> _faltantes = [];

    /// <summary>Texto do bloco do modo normal.</summary>
    private string _texto = string.Empty;

    /// <summary>Bytes da imagem de cabeçalho (quando houver).</summary>
    private byte[]? _cabecalhoBytes;

    /// <summary>Data URI da imagem de cabeçalho, para o preview.</summary>
    private string? _cabecalhoDataUri;

    /// <summary>Bytes da imagem de rodapé (quando houver).</summary>
    private byte[]? _rodapeBytes;

    /// <summary>Data URI da imagem de rodapé, para o preview.</summary>
    private string? _rodapeDataUri;

    /// <summary>Snapshot do HTML ao entrar no modo avançado (para detectar edição).</summary>
    private string _snapshotAvancado = string.Empty;

    /// <summary>Id do textarea que receberá o campo inserido pelo menu.</summary>
    private string _idAlvo = string.Empty;

    /// <summary>Indica se o menu de contexto está aberto.</summary>
    private bool _menuAberto;

    /// <summary>Posição X do menu (px).</summary>
    private double _menuX;

    /// <summary>Posição Y do menu (px).</summary>
    private double _menuY;

    /// <summary>Módulo JS de interop.</summary>
    private IJSObjectReference? _modulo;

    /// <summary>Indica se está no modo normal.</summary>
    private bool EhNormal => Origem == OrigemCriacaoTemplate.Normal;

    /// <summary>Verdadeiro quando é possível voltar ao normal (avançado e HTML intacto).</summary>
    private bool PodeVoltar => !EhNormal && string.Equals(Corpo, _snapshotAvancado, StringComparison.Ordinal);

    /// <summary>Define o modo inicial: se já há HTML, abre no avançado (não dá para remontar o normal).</summary>
    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(Corpo))
            Origem = OrigemCriacaoTemplate.Avancado;
    }

    /// <summary>Recalcula campos e preview quando os parâmetros mudam.</summary>
    protected override void OnParametersSet()
    {
        _campos = ExtratorCamposTemplate.ListarTodos(TipoDados, Motor);
        AtualizarPreview();
    }

    /// <summary>Carrega o módulo JS após a primeira renderização.</summary>
    /// <param name="primeiraVez">Se é a primeira renderização.</param>
    protected override async Task OnAfterRenderAsync(bool primeiraVez)
    {
        if (primeiraVez)
            _modulo = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/BBiCore/bbiComporEmail.js");
    }

    /// <summary>Trata a digitação no editor HTML (modo avançado).</summary>
    /// <param name="e">Evento de input.</param>
    private async Task AoDigitarHtml(ChangeEventArgs e)
    {
        Corpo = e.Value?.ToString() ?? string.Empty;
        await CorpoChanged.InvokeAsync(Corpo);
        AtualizarPreview();
    }

    /// <summary>Trata a digitação no bloco de texto (modo normal) e regenera o HTML.</summary>
    /// <param name="e">Evento de input.</param>
    private async Task AoDigitarTexto(ChangeEventArgs e)
    {
        _texto = e.Value?.ToString() ?? string.Empty;
        await RegerarNormal();
    }

    /// <summary>Recebe a imagem de cabeçalho, guarda como anexo inline e regenera o HTML.</summary>
    /// <param name="e">Evento do seletor de arquivo.</param>
    private async Task AoSubirCabecalho(InputFileChangeEventArgs e)
    {
        (byte[] bytes, string tipo, string nome) = await LerImagem(e.File);
        _cabecalhoBytes = bytes;
        _cabecalhoDataUri = $"data:{tipo};base64,{Convert.ToBase64String(bytes)}";
        SincronizarInline(CidCabecalho, bytes, tipo, nome);
        await RegerarNormal();
    }

    /// <summary>Recebe a imagem de rodapé, guarda como anexo inline e regenera o HTML.</summary>
    /// <param name="e">Evento do seletor de arquivo.</param>
    private async Task AoSubirRodape(InputFileChangeEventArgs e)
    {
        (byte[] bytes, string tipo, string nome) = await LerImagem(e.File);
        _rodapeBytes = bytes;
        _rodapeDataUri = $"data:{tipo};base64,{Convert.ToBase64String(bytes)}";
        SincronizarInline(CidRodape, bytes, tipo, nome);
        await RegerarNormal();
    }

    /// <summary>Remove a imagem de cabeçalho.</summary>
    private async Task RemoverCabecalho()
    {
        _cabecalhoBytes = null;
        _cabecalhoDataUri = null;
        SincronizarInline(CidCabecalho, null, null, string.Empty);
        await RegerarNormal();
    }

    /// <summary>Remove a imagem de rodapé.</summary>
    private async Task RemoverRodape()
    {
        _rodapeBytes = null;
        _rodapeDataUri = null;
        SincronizarInline(CidRodape, null, null, string.Empty);
        await RegerarNormal();
    }

    /// <summary>Lê uma imagem enviada em bytes, respeitando o limite de tamanho.</summary>
    /// <param name="arquivo">Arquivo enviado.</param>
    /// <returns>Bytes, content-type e nome.</returns>
    private static async Task<(byte[] Bytes, string Tipo, string Nome)> LerImagem(IBrowserFile arquivo)
    {
        using MemoryStream ms = new();
        await arquivo.OpenReadStream(LimiteImagemBytes).CopyToAsync(ms);
        string tipo = string.IsNullOrWhiteSpace(arquivo.ContentType) ? "image/png" : arquivo.ContentType;
        return (ms.ToArray(), tipo, arquivo.Name);
    }

    /// <summary>Mantém uma entrada de imagem inline (por ContentId) em sincronia na lista de anexos.</summary>
    /// <param name="contentId">ContentId da imagem.</param>
    /// <param name="bytes">Bytes (nulo remove a entrada).</param>
    /// <param name="tipo">Content-type.</param>
    /// <param name="nome">Nome do arquivo.</param>
    private void SincronizarInline(string contentId, byte[]? bytes, string? tipo, string nome)
    {
        if (Anexos is null)
            return;

        for (int i = Anexos.Count - 1; i >= 0; i--)
            if (string.Equals(Anexos[i].ContentId, contentId, StringComparison.OrdinalIgnoreCase))
                Anexos.RemoveAt(i);

        if (bytes is not null)
            Anexos.Add(new AnexoTemplateDto
            {
                Tipo = TipoAnexo.ArquivoEmbutido,
                Conteudo = bytes,
                ContentType = tipo,
                NomeArquivo = nome,
                ContentId = contentId
            });
    }

    /// <summary>Regera o HTML do modo normal, notifica o binding e refaz o preview.</summary>
    private async Task RegerarNormal()
    {
        Corpo = GerarHtmlNormal();
        await CorpoChanged.InvokeAsync(Corpo);
        AtualizarPreview();
    }

    /// <summary>Monta o HTML do modo normal em tabela Outlook-safe, com as imagens por cid:.</summary>
    /// <returns>HTML do corpo.</returns>
    private string GerarHtmlNormal()
    {
        StringBuilder sb = new();
        sb.Append("<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"border-collapse:collapse\">");

        if (_cabecalhoBytes is not null)
            sb.Append($"<tr><td align=\"center\" style=\"padding:0\"><img src=\"cid:{CidCabecalho}\" alt=\"\" style=\"display:block;max-width:100%;height:auto;border:0\"></td></tr>");

        sb.Append("<tr><td style=\"font-family:Arial,Helvetica,sans-serif;font-size:14px;line-height:1.5;color:#000000;padding:16px\">");
        sb.Append(TextoParaHtml(_texto));
        sb.Append("</td></tr>");

        if (_rodapeBytes is not null)
            sb.Append($"<tr><td align=\"center\" style=\"padding:0\"><img src=\"cid:{CidRodape}\" alt=\"\" style=\"display:block;max-width:100%;height:auto;border:0\"></td></tr>");

        sb.Append("</table>");
        return sb.ToString();
    }

    /// <summary>Converte o texto simples em HTML seguro (escapa &lt; &gt; &amp; e quebras viram &lt;br&gt;), preservando os marcadores.</summary>
    /// <param name="texto">Texto do usuário.</param>
    /// <returns>Fragmento HTML.</returns>
    private static string TextoParaHtml(string texto)
    {
        string escapado = System.Net.WebUtility.HtmlEncode(texto ?? string.Empty);
        escapado = escapado.Replace("\r\n", "\n").Replace("\r", "\n");
        return escapado.Replace("\n", "<br>\n");
    }

    /// <summary>Entra no modo avançado, guardando o snapshot para permitir a volta enquanto intacto.</summary>
    private async Task IrParaAvancado()
    {
        _snapshotAvancado = Corpo;
        Origem = OrigemCriacaoTemplate.Avancado;
        await OrigemChanged.InvokeAsync(Origem);
    }

    /// <summary>Volta ao modo normal (só permitido quando o HTML não foi editado).</summary>
    private async Task VoltarParaNormal()
    {
        if (!PodeVoltar)
            return;

        Origem = OrigemCriacaoTemplate.Normal;
        await OrigemChanged.InvokeAsync(Origem);
        AtualizarPreview();
    }

    /// <summary>Abre o menu de contexto na posição do clique, mirando o textarea informado.</summary>
    /// <param name="e">Evento de mouse.</param>
    /// <param name="idAlvo">Id do textarea onde inserir.</param>
    private void AbrirMenu(MouseEventArgs e, string idAlvo)
    {
        _idAlvo = idAlvo;
        _menuX = e.ClientX;
        _menuY = e.ClientY;
        _menuAberto = true;
    }

    /// <summary>Fecha o menu de contexto.</summary>
    private void FecharMenu() => _menuAberto = false;

    /// <summary>Insere o marcador do campo no textarea alvo, via interop.</summary>
    /// <param name="campo">Campo selecionado.</param>
    private async Task InserirCampo(CampoTemplate campo)
    {
        _menuAberto = false;

        if (_modulo is not null && !string.IsNullOrEmpty(_idAlvo))
            await _modulo.InvokeVoidAsync("inserirNoCursor", _idAlvo, "{{" + campo.Nome + "}}");
    }

    /// <summary>Refaz o preview (resolve com exemplo ou destaca marcadores) e calcula os faltantes. Troca cid: por data URI.</summary>
    private void AtualizarPreview()
    {
        _faltantes = Motor.Validar(Corpo, TipoDados);
        string baseHtml = ResolverCidsParaPreview(Corpo);

        if (DadosExemplo is not null)
        {
            _preview = Motor.Resolver(baseHtml, DadosExemplo).Texto;
            return;
        }

        HashSet<string> faltam = new(_faltantes, StringComparer.OrdinalIgnoreCase);

        _preview = RxMarcador.Replace(baseHtml, m =>
        {
            string nome = m.Groups[1].Value;
            bool ausente = faltam.Contains(nome);
            string estilo = ausente
                ? "background:#fee2e2;color:#b91c1c;"
                : "background:#e0f2fe;color:#0369a1;";
            return $"<span style=\"{estilo}padding:0 2px;border-radius:3px\">{m.Value}</span>";
        });
    }

    /// <summary>Substitui as referências cid: das imagens inline por data URI, só para o preview.</summary>
    /// <param name="html">HTML do corpo.</param>
    /// <returns>HTML com imagens visíveis no preview.</returns>
    private string ResolverCidsParaPreview(string html)
    {
        if (_cabecalhoDataUri is not null)
            html = html.Replace($"cid:{CidCabecalho}", _cabecalhoDataUri);

        if (_rodapeDataUri is not null)
            html = html.Replace($"cid:{CidRodape}", _rodapeDataUri);

        return html;
    }

    /// <summary>Rótulo amigável do grupo de campos no menu.</summary>
    /// <param name="grupo">Grupo do campo.</param>
    /// <returns>Texto do cabeçalho do grupo.</returns>
    private static string RotuloGrupo(GrupoCampo grupo)
    {
        switch (grupo)
        {
            case GrupoCampo.Objeto:
                return "Campos do registro";
            case GrupoCampo.VariavelSistema:
                return "Variáveis do sistema";
            case GrupoCampo.ValorAutomatico:
                return "Valores automáticos";
            default:
                return "Campos";
        }
    }

    /// <summary>Libera o módulo JS ao destruir o componente.</summary>
    public async ValueTask DisposeAsync()
    {
        if (_modulo is not null)
        {
            try
            {
                await _modulo.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuito já encerrado; nada a fazer.
            }
        }
    }
}
