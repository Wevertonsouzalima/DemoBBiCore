@*
    =========================================================================
     BBiEmail.razor  —  Componente completo de e-mail (peça 3, principal)
    -------------------------------------------------------------------------
     Compõe o BBiComporEmail (corpo) e adiciona o envelope: assunto,
     destinatários, cc, cco (todos com marcadores + menu de contexto),
     classificação de sensibilidade, anexos (formas 1 e 3) com política de
     falha, e botões Salvar / Enviar teste.

     FRONTEIRAS
     - Salvar: dispara OnSalvar(ITemplateEmail) para o CONSUMIDOR gravar na
       Email.Templates. O componente não fala com banco.
     - Enviar: aciona o IEnviadorEmail (serviço central da DLL, injetado). O
       componente não abre conexão de rede. Registre o serviço uma vez por
       sistema na injeção de dependência (o stub EnviadorEmailNaoImplementado
       serve de placeholder até o Exchange entrar).

     Depende de BBiEmail.cs (BBiCore.Email) e de wwwroot/bbiComporEmail.js.

     >>> NOTA PARA REORGANIZAÇÃO: manter no namespace BBiCore.Componentes.
    =========================================================================
*@
@namespace BBiCore.Componentes
@using BBiCore.Email
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IEnviadorEmail Enviador

<div class="bbi-mail">
    <div class="bbi-mail__campo">
        <label class="bbi-mail__rotulo" for="@_idAssunto">Assunto</label>
        <input id="@_idAssunto" class="bbi-mail__input" type="text"
               value="@Template.Assunto"
               @oninput="e => AoDigitar(e, v => Template.Assunto = v)"
               @oncontextmenu="e => AbrirMenu(e, _idAssunto)"
               @oncontextmenu:preventDefault="true" />
    </div>

    <div class="bbi-mail__linha">
        <div class="bbi-mail__campo">
            <label class="bbi-mail__rotulo" for="@_idPara">Para (separe por ;)</label>
            <input id="@_idPara" class="bbi-mail__input" type="text"
                   value="@Template.Destinatarios"
                   @oninput="e => AoDigitar(e, v => Template.Destinatarios = v)"
                   @oncontextmenu="e => AbrirMenu(e, _idPara)"
                   @oncontextmenu:preventDefault="true" />
        </div>

        <div class="bbi-mail__campo">
            <label class="bbi-mail__rotulo" for="@_idClass">Classificação</label>
            <select id="@_idClass" class="bbi-mail__input"
                    value="@Template.Classificacao"
                    @onchange="AoMudarClassificacao">
                <option value="@ClassificacaoEmail.Interno">Interno</option>
                <option value="@ClassificacaoEmail.Confidencial">Confidencial</option>
                <option value="@ClassificacaoEmail.Publico">Público</option>
            </select>
        </div>
    </div>

    <div class="bbi-mail__linha">
        <div class="bbi-mail__campo">
            <label class="bbi-mail__rotulo" for="@_idCc">Cc</label>
            <input id="@_idCc" class="bbi-mail__input" type="text"
                   value="@Template.Cc"
                   @oninput="e => AoDigitar(e, v => Template.Cc = v)"
                   @oncontextmenu="e => AbrirMenu(e, _idCc)"
                   @oncontextmenu:preventDefault="true" />
        </div>

        <div class="bbi-mail__campo">
            <label class="bbi-mail__rotulo" for="@_idCco">Cco</label>
            <input id="@_idCco" class="bbi-mail__input" type="text"
                   value="@Template.Cco"
                   @oninput="e => AoDigitar(e, v => Template.Cco = v)"
                   @oncontextmenu="e => AbrirMenu(e, _idCco)"
                   @oncontextmenu:preventDefault="true" />
        </div>
    </div>

    @if (_faltantesEnvelope.Count > 0)
    {
        <div class="bbi-mail__aviso">
            Campos não encontrados no envelope: @string.Join(", ", _faltantesEnvelope.Select(f => "{{" + f + "}}"))
        </div>
    }

    <div class="bbi-mail__secao">
        <span class="bbi-mail__titulo">Corpo</span>
        <BBiComporEmail TipoDados="TipoDados"
                        Motor="Motor"
                        DadosExemplo="DadosExemplo"
                        Anexos="Template.Anexos"
                        @bind-Corpo="Template.Corpo"
                        @bind-Origem="Template.OrigemCriacao" />
    </div>

    <div class="bbi-mail__secao">
        <span class="bbi-mail__titulo">Anexos</span>

        <div class="bbi-mail__anexos">
            @foreach (IAnexoTemplate anexo in AnexosVisiveis)
            {
                <div class="bbi-mail__anexo">
                    <span class="bbi-mail__anexo-nome">
                        @(anexo.Tipo == TipoAnexo.CaminhoDinamico ? anexo.PadraoCaminho : anexo.NomeArquivo)
                    </span>
                    <span class="bbi-mail__anexo-tipo">
                        @(anexo.Tipo == TipoAnexo.CaminhoDinamico ? "caminho dinâmico" : "arquivo fixo")
                    </span>
                    <label class="bbi-mail__anexo-excluir">
                        <input type="checkbox"
                               checked="@anexo.ExcluirAposAnexar"
                               @onchange="e => AlternarExcluir(anexo, e)" />
                        excluir após anexar
                    </label>
                    <button type="button" class="bbi-mail__remover" @onclick="() => RemoverAnexo(anexo)">Remover</button>
                </div>
            }
            @if (AnexosVisiveis.Count == 0)
            {
                <span class="bbi-mail__vazio">Nenhum anexo.</span>
            }
        </div>

        <div class="bbi-mail__anexo-acoes">
            <label class="bbi-mail__botao bbi-mail__botao--sec">
                <InputFile OnChange="AoSubirAnexo" style="display:none" />
                Adicionar arquivo fixo
            </label>

            <div class="bbi-mail__caminho">
                <input class="bbi-mail__input" type="text" placeholder="pedido{{NomeCliente}}.csv"
                       @bind="_novoCaminho" @bind:event="oninput" />
                <button type="button" class="bbi-mail__botao bbi-mail__botao--sec" @onclick="AdicionarCaminho">
                    Adicionar caminho dinâmico
                </button>
            </div>
        </div>

        <div class="bbi-mail__campo bbi-mail__campo--curto">
            <label class="bbi-mail__rotulo" for="@_idFalha">Em caso de falha no anexo</label>
            <select id="@_idFalha" class="bbi-mail__input"
                    value="@Template.AcaoNaFalhaDeAnexo"
                    @onchange="AoMudarFalha">
                <option value="@AcaoFalhaAnexo.EnviarMesmoAssim">Enviar mesmo assim</option>
                <option value="@AcaoFalhaAnexo.FalharEnvio">Falhar o envio</option>
            </select>
        </div>
    </div>

    <div class="bbi-mail__acoes">
        <button type="button" class="bbi-mail__botao" @onclick="Salvar" disabled="@_ocupado">Salvar</button>
        <button type="button" class="bbi-mail__botao bbi-mail__botao--env"
                @onclick="EnviarTeste" disabled="@(_ocupado || DadosExemplo is null)">
            Enviar teste
        </button>
        @if (DadosExemplo is null)
        {
            <span class="bbi-mail__nota">Forneça um objeto de exemplo para habilitar o envio de teste.</span>
        }
        @if (_mensagem is not null)
        {
            <span class="bbi-mail__mensagem @(_envioOk ? "bbi-mail__mensagem--ok" : "bbi-mail__mensagem--erro")">@_mensagem</span>
        }
    </div>

    @if (_menuAberto)
    {
        <div class="bbi-mail__backdrop" @onclick="FecharMenu"></div>
        <div class="bbi-mail__menu" style="left:@(_menuX)px; top:@(_menuY)px;">
            <div class="bbi-mail__menu-titulo">Adicionar campo</div>
            @foreach (IGrouping<GrupoCampo, CampoTemplate> grupo in _campos.GroupBy(c => c.Grupo))
            {
                <div class="bbi-mail__menu-grupo">@RotuloGrupo(grupo.Key)</div>
                @foreach (CampoTemplate campo in grupo)
                {
                    <button type="button" class="bbi-mail__menu-item" @onclick="() => InserirCampo(campo)">@campo.Rotulo</button>
                }
            }
        </div>
    }
</div>

@code {
    /// <summary>Template de e-mail sendo editado. Obrigatório.</summary>
    [Parameter, EditorRequired] public ITemplateEmail Template { get; set; } = default!;

    /// <summary>Tipo do objeto de dados (ex.: PedidoCliente) para campos e validação. Obrigatório.</summary>
    [Parameter, EditorRequired] public Type TipoDados { get; set; } = default!;

    /// <summary>Motor configurado com variáveis e computados. Obrigatório.</summary>
    [Parameter, EditorRequired] public MotorTemplateEmail Motor { get; set; } = default!;

    /// <summary>Instância de exemplo para preview e envio de teste.</summary>
    [Parameter] public object? DadosExemplo { get; set; }

    /// <summary>Disparado ao clicar em Salvar; o consumidor grava o template.</summary>
    [Parameter] public EventCallback<ITemplateEmail> OnSalvar { get; set; }

    /// <summary>Disparado após o envio de teste, com o resultado.</summary>
    [Parameter] public EventCallback<ResultadoEnvio> OnEnviado { get; set; }

    /// <summary>Ids únicos dos campos do envelope (para o interop e o menu).</summary>
    private readonly string _idAssunto = $"bbi-assunto-{Guid.NewGuid():N}";
    private readonly string _idPara = $"bbi-para-{Guid.NewGuid():N}";
    private readonly string _idCc = $"bbi-cc-{Guid.NewGuid():N}";
    private readonly string _idCco = $"bbi-cco-{Guid.NewGuid():N}";
    private readonly string _idClass = $"bbi-class-{Guid.NewGuid():N}";
    private readonly string _idFalha = $"bbi-falha-{Guid.NewGuid():N}";

    /// <summary>Campos disponíveis para inserção.</summary>
    private IReadOnlyList<CampoTemplate> _campos = [];

    /// <summary>Marcadores não encontrados nos campos do envelope.</summary>
    private IReadOnlyList<string> _faltantesEnvelope = [];

    /// <summary>Texto do novo caminho dinâmico em digitação.</summary>
    private string _novoCaminho = string.Empty;

    /// <summary>Estado do menu de contexto.</summary>
    private bool _menuAberto;
    private double _menuX;
    private double _menuY;
    private string _idAlvo = string.Empty;

    /// <summary>Indica processamento em andamento (desabilita botões).</summary>
    private bool _ocupado;

    /// <summary>Mensagem de retorno da última ação e se foi sucesso.</summary>
    private string? _mensagem;
    private bool _envioOk;

    /// <summary>Módulo JS de interop (compartilhado com o editor de corpo).</summary>
    private IJSObjectReference? _modulo;

    /// <summary>Anexos exibidos na seção (exclui as imagens inline, que são do corpo).</summary>
    private IReadOnlyList<IAnexoTemplate> AnexosVisiveis
        => Template.Anexos.Where(a => a.ContentId is null).ToList();

    /// <summary>Recalcula campos e validação do envelope quando os parâmetros mudam.</summary>
    protected override void OnParametersSet()
    {
        _campos = ExtratorCamposTemplate.ListarTodos(TipoDados, Motor);
        AtualizarValidacaoEnvelope();
    }

    /// <summary>Carrega o módulo JS após a primeira renderização.</summary>
    /// <param name="primeiraVez">Se é a primeira renderização.</param>
    protected override async Task OnAfterRenderAsync(bool primeiraVez)
    {
        if (primeiraVez)
            _modulo = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/BBiCore/bbiComporEmail.js");
    }

    /// <summary>Grava o valor digitado no destino e revalida o envelope.</summary>
    /// <param name="e">Evento de input.</param>
    /// <param name="destino">Ação que grava o valor na propriedade certa.</param>
    private void AoDigitar(ChangeEventArgs e, Action<string> destino)
    {
        destino(e.Value?.ToString() ?? string.Empty);
        AtualizarValidacaoEnvelope();
    }

    /// <summary>Atualiza a classificação do template.</summary>
    /// <param name="e">Evento de mudança.</param>
    private void AoMudarClassificacao(ChangeEventArgs e)
    {
        if (Enum.TryParse(e.Value?.ToString(), out ClassificacaoEmail valor))
            Template.Classificacao = valor;
    }

    /// <summary>Atualiza a política de falha de anexo.</summary>
    /// <param name="e">Evento de mudança.</param>
    private void AoMudarFalha(ChangeEventArgs e)
    {
        if (Enum.TryParse(e.Value?.ToString(), out AcaoFalhaAnexo valor))
            Template.AcaoNaFalhaDeAnexo = valor;
    }

    /// <summary>Revalida os quatro campos do envelope, juntando os marcadores desconhecidos.</summary>
    private void AtualizarValidacaoEnvelope()
    {
        string juntos = string.Join(
            "\n",
            Template.Assunto ?? string.Empty,
            Template.Destinatarios ?? string.Empty,
            Template.Cc ?? string.Empty,
            Template.Cco ?? string.Empty);

        _faltantesEnvelope = Motor.Validar(juntos, TipoDados);
    }

    /// <summary>Recebe um arquivo fixo e adiciona como anexo embutido.</summary>
    /// <param name="e">Evento do seletor de arquivo.</param>
    private async Task AoSubirAnexo(InputFileChangeEventArgs e)
    {
        IBrowserFile arquivo = e.File;
        using MemoryStream ms = new();
        await arquivo.OpenReadStream(20L * 1024 * 1024).CopyToAsync(ms);

        Template.Anexos.Add(new AnexoTemplateDto
        {
            Tipo = TipoAnexo.ArquivoEmbutido,
            Conteudo = ms.ToArray(),
            ContentType = string.IsNullOrWhiteSpace(arquivo.ContentType) ? "application/octet-stream" : arquivo.ContentType,
            NomeArquivo = arquivo.Name
        });
    }

    /// <summary>Adiciona um anexo de caminho dinâmico a partir do padrão digitado.</summary>
    private void AdicionarCaminho()
    {
        if (string.IsNullOrWhiteSpace(_novoCaminho))
            return;

        Template.Anexos.Add(new AnexoTemplateDto
        {
            Tipo = TipoAnexo.CaminhoDinamico,
            PadraoCaminho = _novoCaminho.Trim(),
            NomeArquivo = _novoCaminho.Trim()
        });

        _novoCaminho = string.Empty;
    }

    /// <summary>Alterna a marca de "excluir após anexar" de um anexo (recria a entrada, pois o DTO é a implementação).</summary>
    /// <param name="anexo">Anexo alvo.</param>
    /// <param name="e">Evento do checkbox.</param>
    private void AlternarExcluir(IAnexoTemplate anexo, ChangeEventArgs e)
    {
        bool valor = e.Value is bool b && b;

        if (anexo is AnexoTemplateDto dto)
            dto.ExcluirAposAnexar = valor;
    }

    /// <summary>Remove um anexo da lista.</summary>
    /// <param name="anexo">Anexo a remover.</param>
    private void RemoverAnexo(IAnexoTemplate anexo) => Template.Anexos.Remove(anexo);

    /// <summary>Abre o menu de contexto na posição do clique, mirando o campo informado.</summary>
    /// <param name="e">Evento de mouse.</param>
    /// <param name="idAlvo">Id do campo onde inserir.</param>
    private void AbrirMenu(MouseEventArgs e, string idAlvo)
    {
        _idAlvo = idAlvo;
        _menuX = e.ClientX;
        _menuY = e.ClientY;
        _menuAberto = true;
    }

    /// <summary>Fecha o menu de contexto.</summary>
    private void FecharMenu() => _menuAberto = false;

    /// <summary>Insere o marcador do campo no alvo, via interop, e revalida.</summary>
    /// <param name="campo">Campo selecionado.</param>
    private async Task InserirCampo(CampoTemplate campo)
    {
        _menuAberto = false;

        if (_modulo is not null && !string.IsNullOrEmpty(_idAlvo))
            await _modulo.InvokeVoidAsync("inserirNoCursor", _idAlvo, "{{" + campo.Nome + "}}");
    }

    /// <summary>Dispara o salvamento para o consumidor.</summary>
    private async Task Salvar()
    {
        _mensagem = null;
        await OnSalvar.InvokeAsync(Template);
        _envioOk = true;
        _mensagem = "Template enviado para salvamento.";
    }

    /// <summary>Resolve o template com o objeto de exemplo e aciona o serviço central de envio.</summary>
    private async Task EnviarTeste()
    {
        if (DadosExemplo is null)
            return;

        _ocupado = true;
        _mensagem = null;
        StateHasChanged();

        EmailResolvido resolvido = ResolvedorEmail.Resolver(Template, DadosExemplo, Motor);
        ResultadoEnvio resultado = await Enviador.EnviarAsync(resolvido);

        _envioOk = resultado.Sucesso;
        _mensagem = resultado.Mensagem ?? (resultado.Sucesso ? "Enviado." : "Falha no envio.");
        _ocupado = false;

        await OnEnviado.InvokeAsync(resultado);
    }

    /// <summary>Rótulo amigável do grupo de campos no menu.</summary>
    /// <param name="grupo">Grupo do campo.</param>
    /// <returns>Texto do cabeçalho do grupo.</returns>
    private static string RotuloGrupo(GrupoCampo grupo)
    {
        switch (grupo)
        {
            case GrupoCampo.Objeto:
                return "Campos do registro";
            case GrupoCampo.VariavelSistema:
                return "Variáveis do sistema";
            case GrupoCampo.ValorAutomatico:
                return "Valores automáticos";
            default:
                return "Campos";
        }
    }

    /// <summary>Libera o módulo JS ao destruir o componente.</summary>
    public async ValueTask DisposeAsync()
    {
        if (_modulo is not null)
        {
            try
            {
                await _modulo.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuito já encerrado; nada a fazer.
            }
        }
    }
}
